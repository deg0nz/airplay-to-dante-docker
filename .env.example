# ── Dante VLAN ────────────────────────────────────────────────────────────────
DANTE_IP=10.1.1.203
DANTE_HOST_INTERFACE=eth0.10        # VLAN-tagged interface on the host
DANTE_SUBNET=10.1.1.0/24
DANTE_GATEWAY=10.1.1.1

# ── Client VLAN ───────────────────────────────────────────────────────────────
AIRPLAY_IP=192.168.1.150
AIRPLAY_HOST_INTERFACE=eth0.1       # or eth1 if separate physical interface
AIRPLAY_SUBNET=192.168.1.0/24
AIRPLAY_GATEWAY=192.168.1.1

# ── Container config ──────────────────────────────────────────────────────────
AIRPLAY_NAME=Dante Bridge
DANTE_DEVICE_NAME=inferno
