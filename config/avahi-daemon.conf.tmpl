[server]
host-name=${DANTE_DEVICE_NAME}
domain-name=local
use-ipv4=yes
use-ipv6=no
allow-interfaces=${AIRPLAY_INTERFACE}
deny-interfaces=${DANTE_INTERFACE}
ratelimit-interval-usec=1000000
ratelimit-burst=1000

[wide-area]
enable-wide-area=yes

[publish]
publish-hinfo=yes
publish-workstation=no

[reflector]
enable-reflector=no

[rlimits]
rlimit-core=0
rlimit-data=4194304
rlimit-fsize=0
rlimit-nofile=768
rlimit-stack=4194304
rlimit-nproc=3
